# ===========================================================
# ⚠️ CRITICAL WARNING - READ THIS FIRST!
# ===========================================================
# This bot uses an UNOFFICIAL WhatsApp client and VIOLATES 
# WhatsApp Terms of Service. Your account WILL be banned 
# eventually. ONLY use with burner numbers you're willing to lose.
#
# 🔴 DO NOT use with your main WhatsApp number!
# 🔴 DO NOT enable auto-features unless you understand the risks!
# 🔴 NEVER commit this file to GitHub!
# ===========================================================

# ===========================================================
# 1. SERVER CONFIGURATION
# ===========================================================

# Port the server will run on (default: 3000)
PORT=3000

# Environment: development or production
NODE_ENV=production

# ===========================================================
# 2. DATABASE CONFIGURATION (REQUIRED)
# ===========================================================

# MongoDB Connection String
# Get from: https://cloud.mongodb.com/
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DATABASE_NAME
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/minibot

# ===========================================================
# 3. MEGA STORAGE (REQUIRED FOR PAIRING CODES)
# ===========================================================

# MEGA.nz Account Credentials
# Create free account at: https://mega.nz/
# ⚠️ These are REQUIRED for the pairing system to work!
MEGA_EMAIL=myhuxna@gmail.com
MEGA_PASSWORD=Dodoma2006#
MEGA_FOLDER=pairing_codes

# ===========================================================
# 4. BOT CONFIGURATION
# ===========================================================

# Command prefix (default: .)
PREFIX=.

# Your WhatsApp number (without + or spaces)
# Example: 254712345678
OWNER_NUMBER=254735638957

# Your display name
OWNER_NAME=YourName

# Bot display name
BOT_NAME=NAPPIER-XMD

# Bot version
VERSION=2.0.0

# Work mode options:
# public   - Responds to everyone
# private  - Only responds to owner
# inbox    - Only responds in private chats
# group    - Only responds in groups
# ⚠️ RECOMMENDED: Use "private" for testing!
WORK_TYPE=private

# ===========================================================
# 5. SESSION & PAIRING CONFIGURATION
# ===========================================================

# Where to store WhatsApp sessions
SESSION_DIR=./session

# Where to store local pairing code backups
PAIRING_CODES_DIR=./pairing_codes

# Pairing code expiry time (in milliseconds)
# 120000ms = 2 minutes
PAIRING_EXPIRY_MS=120000

# Maximum pairing attempts per number
MAX_PAIRING_ATTEMPTS=3

# ===========================================================
# 6. AUTO FEATURES - 🔴 KEEP DISABLED FOR SAFETY!
# ===========================================================

# ⚠️ WARNING: Enabling these can trigger WhatsApp's bot detection
# and cause immediate bans. Keep all set to false!

# Auto-view status updates
AUTO_VIEW_STATUS=false

# Auto-like (react) to status updates
AUTO_LIKE_STATUS=false

# Auto-read status updates
AUTO_READ_STATUS=false

# Auto-react to status updates
AUTO_REACT_STATUS=false

# Auto-reply to status updates
AUTO_STATUS_REPLY=false
AUTO_STATUS_MSG=🤗

# ===========================================================
# 7. CHAT PRESENCE - 🔴 KEEP DISABLED!
# ===========================================================

# 🔴 DO NOT ENABLE - These trigger detection and cause bans!
READ_MESSAGE=false
AUTO_TYPING=false
AUTO_RECORDING=false

# ===========================================================
# 8. GROUP MANAGEMENT - 🔴 KEEP DISABLED!
# ===========================================================

# Welcome messages (triggers bot detection)
WELCOME_ENABLE=false
GOODBYE_ENABLE=false

# ===========================================================
# 9. AUTO REACT - USE WITH EXTREME CAUTION
# ===========================================================

# Numbers to auto-react to (comma-separated)
AUTO_REACT_NUMBERS=254735638957

# Emojis for auto-reaction
AUTO_REACT_EMOJIS=❤️,🔥,💯,👑,⚡

# ===========================================================
# 10. SECURITY SETTINGS
# ===========================================================

# Reject incoming calls
ANTI_CALL=true
REJECT_MSG=📵 This bot doesn't accept calls

# Anti-delete message tracking
ANTI_DELETE=true

# ===========================================================
# 11. RECONNECT & SAFETY SETTINGS
# ===========================================================

# Maximum restart attempts before giving up
MAX_RESTARTS=5

# Delay between restart attempts (in milliseconds)
RESTART_BACKOFF_MS=5000

# ===========================================================
# 12. RATE LIMITING (Optional)
# ===========================================================

# Maximum commands per minute per user
RATE_LIMIT_COMMANDS=10

# Maximum messages per minute per user
RATE_LIMIT_MESSAGES=30

# ===========================================================
# 13. LOGGING & DEBUGGING
# ===========================================================

# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# Enable detailed debugging (true/false)
DEBUG_MODE=false

# ===========================================================
# 14. TELEGRAM BOT (Optional - Disabled by default)
# ===========================================================

# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=

# ===========================================================
# 15. IMAGES & EXTERNAL LINKS
# ===========================================================

# Bot profile image URL
IMAGE_PATH=https://files.catbox.moe/99ofzd.jpg

# Web pairing URL
WEB_PAIR_URL=http://localhost:3000

# ===========================================================
# 16. 🔴 NEWSLETTER - COMPLETELY REMOVED!
# ===========================================================

# ⚠️ Newsletter features have been removed from the codebase
# They were causing automatic bans. DO NOT attempt to add them back.

# ===========================================================
# 📋 QUICK SETUP CHECKLIST
# ===========================================================

# ✅ MONGODB_URI     - Set your MongoDB connection string
# ✅ MEGA_EMAIL      - Set your MEGA account email
# ✅ MEGA_PASSWORD   - Set your MEGA account password
# ✅ OWNER_NUMBER    - Set your WhatsApp number
# ✅ BOT_NAME        - Set your bot's display name
# ⚠️ WORK_TYPE      - Set to "private" for testing
# ⚠️ AUTO_*         - Keep ALL disabled for safety!

# ===========================================================
# 🔴 CRITICAL SECURITY REMINDERS
# ===========================================================

# 1. 🔴 NEVER commit .env to GitHub!
# 2. 🔴 NEVER share your MongoDB URI!
# 3. 🔴 NEVER share your MEGA credentials!
# 4. 🔴 NEVER share your Telegram bot token!
# 5. 🔴 NEVER use your main WhatsApp number!
# 6. 🔴 WhatsApp WILL ban this account eventually!
# 7. 🔴 This violates WhatsApp Terms of Service!
# 8. 🔴 For production, use official WhatsApp Cloud API!

# ===========================================================
# 🛡️ SAFETY RECOMMENDATIONS
# ===========================================================

# 1. Start with WORK_TYPE=private
# 2. Keep all AUTO_* features disabled
# 3. Test with a burner number first
# 4. Monitor bot behavior closely
# 5. Have a backup number ready
# 6. Expect account bans (it's inevitable)
