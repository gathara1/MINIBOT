# ⚠️ CRITICAL: Read README.md before using this bot!
# This bot uses an UNOFFICIAL WhatsApp client and WILL ban your account
# Only use with burner numbers you're willing to lose

# ===========================================================
# 1. SERVER CONFIGURATION
# ===========================================================
PORT=3000
NODE_ENV=production

# ===========================================================
# 2. BASE CONFIGURATION
# ===========================================================
SESSION_ID=NAPPIER-XMD
# Use MongoDB Atlas or local MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/minibot

# ===========================================================
# 3. BOT INFORMATION
# ===========================================================
PREFIX=.
OWNER_NUMBER=254735638957
OWNER_NAME=YourName
BOT_NAME=NAPPIER-XMD
WORK_TYPE=public
VERSION=2.0.0

# ===========================================================
# 4. MEGA STORAGE - REQUIRED FOR PAIRING CODES
# ===========================================================
# ⚠️ REQUIRED: MEGA account for storing pairing codes
# Create free account at https://mega.nz
MEGA_EMAIL=your-email@example.com
MEGA_PASSWORD=your-mega-password
MEGA_FOLDER=pairing_codes

# ===========================================================
# 5. AUTO FEATURES - KEEP DISABLED FOR SAFETY
# ===========================================================
# ⚠️ WARNING: Enabling these can trigger WhatsApp's bot detection
AUTO_VIEW_STATUS=false
AUTO_LIKE_STATUS=false
AUTO_READ_STATUS=false
AUTO_REACT_STATUS=false
AUTO_STATUS_REPLY=false
AUTO_STATUS_MSG=🤗

# ===========================================================
# 6. CHAT & PRESENCE - DISABLED FOR BAN SAFETY
# ===========================================================
# 🔴 DO NOT ENABLE - These trigger detection and cause bans
READ_MESSAGE=false
AUTO_TYPING=false
AUTO_RECORDING=false

# ===========================================================
# 7. GROUP MANAGEMENT
# ===========================================================
WELCOME_ENABLE=false
GOODBYE_ENABLE=false
GROUP_LINK=https://chat.whatsapp.com/CLClgqJIC59GrcI4sRzLu8

# ===========================================================
# 8. SECURITY & ANTI-FEATURES
# ===========================================================
ANTI_CALL=true
REJECT_MSG=📵 This bot doesn't accept calls
ANTI_DELETE=true

# ===========================================================
# 9. IMAGES & LINKS
# ===========================================================
IMAGE_PATH=https://files.catbox.moe/99ofzd.jpg
CHANNEL_LINK=https://whatsapp.com/channel/0029VbCPRUwLI8YhL4yg9l0y
WEB_PAIR_URL=http://localhost:8000

# ===========================================================
# 10. 🔴 NEWSLETTER - REMOVED FOR BAN SAFETY
# ===========================================================
# ⚠️ DO NOT ENABLE - Newsletter features have been removed
# to prevent automatic bans. They are no longer active in code.
NEWSLETTER_JID=
ENABLE_AUTO_FOLLOW_NEWSLETTER=false
AUTO_JOIN_GROUP=

# ===========================================================
# 11. AUTO REACT - USE WITH EXTREME CAUTION
# ===========================================================
AUTO_REACT_NUMBERS=254735638957
AUTO_REACT_EMOJIS=❤️,🔥,💯,👑,⚡
# 🔴 Newsletter channel reactions DISABLED - caused bans
CHANNEL_REACT=false
CHANNEL_REACT_EMOJIS=

# ===========================================================
# 12. TELEGRAM BOT (Optional)
# ===========================================================
# Get token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHAT_ID=

# ===========================================================
# 13. RECONNECT / SAFETY
# ===========================================================
MAX_RESTARTS=5
RESTART_BACKOFF_MS=5000

# ===========================================================
# 14. PAIRING CONFIGURATION
# ===========================================================
# Pairing code expiry time (in milliseconds)
PAIRING_EXPIRY_MS=120000
# Maximum pairing attempts per number
MAX_PAIRING_ATTEMPTS=3

# ===========================================================
# 15. SESSION DIRECTORIES
# ===========================================================
SESSION_DIR=./session
PAIRING_CODES_DIR=./pairing_codes

# ===========================================================
# 16. RATE LIMITING (Optional)
# ===========================================================
RATE_LIMIT_COMMANDS=10
RATE_LIMIT_MESSAGES=30

# ===========================================================
# 17. LOGGING
# ===========================================================
LOG_LEVEL=info
DEBUG_MODE=false

# ===========================================================
# ⚠️ SECURITY NOTES
# ===========================================================
# 1. NEVER commit .env to GitHub
# 2. NEVER share your MongoDB URI
# 3. NEVER share your TELEGRAM_BOT_TOKEN
# 4. NEVER share your MEGA credentials
# 5. ONLY use with burner WhatsApp numbers
# 6. WhatsApp WILL ban this account eventually
# 7. This violates WhatsApp Terms of Service
# 8. For production, use official WhatsApp Cloud API

# ===========================================================
# 📋 QUICK SETUP CHECKLIST
# ===========================================================
# ✅ MONGODB_URI - Set your MongoDB connection string
# ✅ MEGA_EMAIL - Set your MEGA account email
# ✅ MEGA_PASSWORD - Set your MEGA account password
# ✅ OWNER_NUMBER - Set your WhatsApp number
# ✅ BOT_NAME - Set your bot's display name
# ⚠️ AUTO_* - Keep all disabled for safety
# ⚠️ WORK_TYPE - Set to 'private' for testing first
